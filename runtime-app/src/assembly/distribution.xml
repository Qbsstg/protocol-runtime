<?xml version="1.0" encoding="UTF-8"?>
<assembly xmlns="http://maven.apache.org/ASSEMBLY/2.1.0"
          xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
          xsi:schemaLocation="http://maven.apache.org/ASSEMBLY/2.1.0 https://maven.apache.org/xsd/assembly-2.1.0.xsd">
    <id>distribution</id>
    <formats>
        <format>zip</format>
        <format>tar.gz</format>
    </formats>
    <includeBaseDirectory>true</includeBaseDirectory>
    <baseDirectory>protocol-runtime-${project.version}</baseDirectory>

    <files>
        <file>
            <source>${project.build.directory}/${project.build.finalName}-standalone.jar</source>
            <outputDirectory>lib</outputDirectory>
            <destName>runtime-app-${project.version}-standalone.jar</destName>
            <fileMode>0644</fileMode>
        </file>
        <file>
            <source>${project.basedir}/../LICENSE</source>
            <outputDirectory>.</outputDirectory>
            <fileMode>0644</fileMode>
        </file>
        <file>
            <source>${project.basedir}/../README.md</source>
            <outputDirectory>.</outputDirectory>
            <fileMode>0644</fileMode>
        </file>
        <file>
            <source>${project.basedir}/../README.zh-CN.md</source>
            <outputDirectory>.</outputDirectory>
            <fileMode>0644</fileMode>
        </file>
        <file>
            <source>${project.build.directory}/dist-metadata/package.properties</source>
            <outputDirectory>.</outputDirectory>
            <fileMode>0644</fileMode>
        </file>
    </files>

    <fileSets>
        <fileSet>
            <directory>${project.basedir}/src/dist/bin</directory>
            <outputDirectory>bin</outputDirectory>
            <fileMode>0755</fileMode>
            <lineEnding>unix</lineEnding>
        </fileSet>
        <fileSet>
            <directory>${project.basedir}/src/dist/conf</directory>
            <outputDirectory>conf</outputDirectory>
            <fileMode>0644</fileMode>
            <lineEnding>unix</lineEnding>
        </fileSet>
        <fileSet>
            <directory>${project.basedir}/src/dist/logs</directory>
            <outputDirectory>logs</outputDirectory>
            <fileMode>0644</fileMode>
        </fileSet>
        <fileSet>
            <directory>${project.basedir}/src/dist/data</directory>
            <outputDirectory>data</outputDirectory>
            <fileMode>0644</fileMode>
        </fileSet>
        <fileSet>
            <directory>${project.basedir}/src/dist/run</directory>
            <outputDirectory>run</outputDirectory>
            <fileMode>0644</fileMode>
        </fileSet>
        <fileSet>
            <directory>${project.basedir}/src/dist/tmp</directory>
            <outputDirectory>tmp</outputDirectory>
            <fileMode>0644</fileMode>
        </fileSet>
        <fileSet>
            <directory>${project.basedir}/../docs</directory>
            <outputDirectory>docs</outputDirectory>
            <includes>
                <include>distribution-package.md</include>
                <include>distribution-package.zh-CN.md</include>
                <include>deployment-governance.md</include>
                <include>deployment-governance.zh-CN.md</include>
                <include>operations-runbook.md</include>
                <include>operations-runbook.zh-CN.md</include>
                <include>status-health-readiness.md</include>
                <include>status-health-readiness.zh-CN.md</include>
            </includes>
            <fileMode>0644</fileMode>
        </fileSet>
        <fileSet>
            <directory>${project.basedir}/../examples</directory>
            <outputDirectory>examples</outputDirectory>
            <includes>
                <include>Iec104SendSinglePoint.java</include>
                <include>protocol-runtime.service</include>
                <include>com.qbsstg.protocol-runtime.plist</include>
            </includes>
            <fileMode>0644</fileMode>
            <lineEnding>unix</lineEnding>
        </fileSet>
    </fileSets>
</assembly>
